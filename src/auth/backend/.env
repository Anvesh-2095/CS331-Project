# --- SERVER CONFIGURATION ---
PORT=8001
HOST=0.0.0.0
ENVIRONMENT=development

# --- POSTGRES DATABASE CONFIGURATION ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=soar_admin
DB_PASSWORD=super_secret_db_password
DB_NAME=soar_auth_db

# --- OAUTH2 / JWT SECRETS ---
# Run `openssl rand -hex 32` in your terminal to generate secure keys for production
JWT_SECRET_KEY=your_super_secret_jwt_signing_key_here
JWT_ALGORITHM=HS256

# --- SESSION TIMEOUTS (in minutes) ---
# Access tokens are short-lived for security
ACCESS_TOKEN_EXPIRE_MINUTES=5

# Refresh tokens control the sliding session max limits
REFRESH_TOKEN_EXPIRE_ANALYST_MINUTES=30
REFRESH_TOKEN_EXPIRE_ADMIN_MINUTES=60