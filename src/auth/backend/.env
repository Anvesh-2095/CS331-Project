# Server Config
PORT=8001

# Security Secrets (Change this in production)
JWT_SECRET_KEY=your_super_secret_jwt_signing_key_here
JWT_ALGORITHM=HS256

# Sliding Session Timeouts (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_ANALYST_MINUTES=30
REFRESH_TOKEN_EXPIRE_ADMIN_MINUTES=60

# PostgreSQL Connection
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/soar_auth_db